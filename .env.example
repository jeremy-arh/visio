NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT (générer une clé sécurisée en production)
JWT_SECRET=your-jwt-secret-min-32-chars

# App URL (pour les liens dans les emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Daily.co (optionnel - pour la vidéo)
DAILY_API_KEY=

# Veriff (optionnel - pour le KYC)

# Yousign (optionnel - pour les signatures)
# YOUSIGN_API_KEY=
# YOUSIGN_WEBHOOK_SECRET=

# Twilio (optionnel - SMS notaire)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# SendGrid (optionnel - emails)
# SENDGRID_API_KEY=
